# Maven build output
target/
*.class

# SQLite databases & logs in data directory
src/data/*.db
src/data/*.db-shm
src/data/*.db-wal
src/data/*.log

# Client test data directories (preserve structure via .gitkeep)
src/data/client/*
!src/data/client/.gitkeep
!src/data/.gitkeep

# IDE files
.idea/
.vscode/
*.iml
*.iws

# JVM crash logs and general logs
src/hs_err_pid*.log
**/logs/
src/kdc-server/data/

# Standalone packaged ZIPs
*.zip
